<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              name="DiaryReport" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">

    <!-- User ID parameter -->
    <parameter name="USER_ID" class="java.lang.Integer"/>

    <!-- Query to get diary entries for this user -->
    <queryString>
        <![CDATA[
        SELECT e.title, e.entry_date, e.mood, c.category_name
        FROM diary_entries e
        JOIN categories c ON e.category_id=c.category_id
        WHERE e.user_id = $P{USER_ID}
        ORDER BY e.entry_date
        ]]>
    </queryString>

    <field name="title" class="java.lang.String"/>
    <field name="entry_date" class="java.lang.String"/>
    <field name="mood" class="java.lang.String"/>
    <field name="category_name" class="java.lang.String"/>

    <title>
        <band height="50">
            <staticText>
                <reportElement x="0" y="0" width="555" height="30"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="18" isBold="true"/>
                </textElement>
                <text><![CDATA[Diary Entries Report]]></text>
            </staticText>
        </band>
    </title>

    <detail>
        <band height="20">
            <textField>
                <reportElement x="0" y="0" width="150" height="20"/>
                <textFieldExpression><![CDATA[$F{title}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="150" y="0" width="100" height="20"/>
                <textFieldExpression><![CDATA[$F{entry_date}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="250" y="0" width="100" height="20"/>
                <textFieldExpression><![CDATA[$F{mood}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="350" y="0" width="150" height="20"/>
                <textFieldExpression><![CDATA[$F{category_name}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

</jasperReport>